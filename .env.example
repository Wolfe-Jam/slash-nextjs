# Required — at least one provider
# Claude is the default / most popular, but any of these works.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...
# GOOGLE_GENERATIVE_AI_API_KEY=...

# Optional — enables Slash dashboard tracking
# Get a free key (includes $5 credit) at https://mcpaas.live/slash/setup
# SLASH_KEY=mcp_slash_...

# Optional — override the Slash proxy endpoint
# SLASH_PROXY_URL=https://mcpaas.live/slash/v1
